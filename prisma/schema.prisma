// Prisma schema — Portfolio
// Default datasource: SQLite (works on Z.ai sandbox).
// To deploy on Vercel: change provider to "postgresql" and set DATABASE_URL to Vercel Postgres / Neon.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // FOR VERCEL DEPLOY: Change to provider = "postgresql"
  // FOR LOCAL DEV: Keep as "sqlite"
  // See prisma/schema.local.prisma for the SQLite version
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id             String   @id @default("profile")
  name           String   @default("Amine")
  heroGreeting   String   @default("Hi! I'm")
  roles          String   @default("Frontend Developer,CS Student")
  rotatingRoles  String   @default("Software Developer,Frontend Developer,CS Student,Designer,Creator,Problem Solver")
  city           String   @default("")
  bio            String   @default("")
  email          String   @default("contact@amine.com")
  phone          String   @default("+123 456 7890")
  location       String   @default("City, Country")
  heroImage      String   @default("/images/hero-character.png")
  aboutImage     String   @default("/images/about-character.png")
  github         String   @default("https://github.com")
  instagram      String   @default("https://instagram.com")
  linkedin       String   @default("https://linkedin.com")
  logoText       String   @default("amine")
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

model Project {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  description   String   @default("")
  technologies  String   @default("")
  githubUrl     String   @default("")
  liveUrl       String   @default("")
  coverImage    String   @default("")
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([order])
}

model Service {
  id          String @id @default(cuid())
  title       String
  description String
  icon        String // lucide icon name
  order       Int    @default(0)

  @@index([order])
}

model TechStack {
  id    String @id @default(cuid())
  name  String
  icon  String // simple-icons slug or lucide name
  order Int    @default(0)

  @@index([order])
}

model Stat {
  id     String @id @default(cuid())
  label  String
  value  Int
  suffix String @default("+")
  order  Int    @default(0)

  @@index([order])
}

model SiteSettings {
  id               String  @id @default("settings")
  availabilityText String  @default("Available for projects")
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
